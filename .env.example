# ============================================
# SERVER ENVIRONMENT CONFIGURATION
# ============================================

# ============================================
# MONGODB DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=portfolio

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port
PORT=5000

# Node environment (development/production)
NODE_ENV=development

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
# JWT secret for token signing (minimum 32 characters for production)
JWT_SECRET=your_secure_jwt_secret_minimum_32_characters_change_in_production

# ============================================
# CORS & CLIENT CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000,http://localhost:3001

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Comma-separated list of admin email addresses
ADMIN_EMAILS=your-email@example.com,admin@example.com

# ============================================
# EMAIL CONFIGURATION (Optional - for password reset)
# ============================================
# Gmail address for sending emails
EMAIL_USER=your-email@gmail.com

# Gmail App Password (not regular password - use app-specific password from Google Account)
EMAIL_PASS=your_gmail_app_password
# Comma-separated list of allowed client URLs
# Used for CORS preflight and redirects
CLIENT_URL=http://localhost:3000,http://localhost:3001

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Comma-separated list of admin emails
# Users with these emails automatically get admin role
ADMIN_EMAILS=masud.dev01@gmail.com,mr3377006@gmail.com,masudranamdra@gmail.com

# ============================================
# DEPLOYMENT NOTES
# ============================================
# For Render Backend Deployment:
# 1. Set NODE_ENV=production
# 2. Update MONGODB_URI to your MongoDB Atlas connection string
# 3. Update CLIENT_URL to your frontend production domain
# 4. Generate a new JWT_SECRET: openssl rand -base64 32
# 5. Ensure MongoDB Atlas has Render IP whitelisted
